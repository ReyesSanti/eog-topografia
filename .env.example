# Variables de entorno de la función serverless `api/contact`.
# En Vercel: Project → Settings → Environment Variables (NO se suben al repo).

# Resend — clave para enviar el correo. https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# hCaptcha — SECRET key (panel de hCaptcha → tu sitio). Nunca en el cliente.
HCAPTCHA_SECRET=ES_xxxxxxxxxxxxxxxxxxxxxxxx

# Correo destino de las solicitudes (opcional; por defecto eogtopografiasas@gmail.com)
CONTACT_TO_EMAIL=eogtopografiasas@gmail.com

# Remitente (opcional; por defecto onboarding@resend.dev).
# Para usar contacto@eogtopografia.com, verifica el dominio en Resend primero.
MAIL_FROM=EOG Topografía <onboarding@resend.dev>

# Upstash Redis (OPCIONAL) — rate limiting distribuido ante ataques grandes.
# Crea una base gratis en upstash.com → Redis → REST API, y copia ambas.
# Si faltan, la función usa el limitador en memoria (igual funciona).
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx
